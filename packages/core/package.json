{
  "name": "@sportviz/core",
  "version": "0.1.0",
  "description": "Framework-agnostic sports data visualization engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "keywords": ["sports", "visualization", "basketball", "shot-chart", "hexbin", "svg", "data-viz"],
  "author": "Tripp Horbinski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tripp-horbinski/sportviz.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tripp-horbinski/sportviz"
}
