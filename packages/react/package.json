{
  "name": "@tripp-horbinski/sportviz",
  "version": "0.2.0",
  "description": "Composable sports data visualization for React — basketball courts, shot charts, hexbin heatmaps, zone efficiency, play animations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --external react --external react-dom && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "cp ../../README.md . && bun run build",
    "test": "bun test"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@sportviz/core": "workspace:*",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "keywords": [
    "sports",
    "visualization",
    "basketball",
    "shot-chart",
    "react",
    "svg",
    "data-viz",
    "hexbin",
    "court"
  ],
  "author": "Tripp Horbinski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tripp-horbinski/sportviz.git"
  },
  "homepage": "https://github.com/tripp-horbinski/sportviz"
}
