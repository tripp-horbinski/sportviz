{
  "name": "@basketball-ceo/charts",
  "version": "0.2.0",
  "description": "Composable basketball visualization for React — courts, shot charts, hexbin heatmaps, zone efficiency, play animations. NBA, NCAA, WNBA, FIBA.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --external react --external react-dom && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@basketball-ceo/core": "^0.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "keywords": [
    "basketball",
    "shot-chart",
    "hexbin",
    "nba",
    "ncaa",
    "wnba",
    "court",
    "react",
    "data-viz",
    "svg"
  ],
  "author": "Tripp Horbinski (https://basketball.ceo)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tripp-horbinski/sportviz.git",
    "directory": "packages/react"
  },
  "homepage": "https://basketball.ceo",
  "publishConfig": {
    "access": "public"
  }
}
